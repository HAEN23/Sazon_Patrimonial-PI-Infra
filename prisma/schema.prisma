generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model administrator {
  userId    Int      @id
  createdAt DateTime @default(now())
  usuario   usuario  @relation(fields: [userId], references: [id_usuario], onDelete: Cascade)
}

model application {
  id                     Int               @id @default(autoincrement())
  proposedRestaurantName String            @db.VarChar(100)
  ownerName              String            @db.VarChar(100)
  email                  String            @db.VarChar(100)
  schedule               String            @db.VarChar(255)
  status                 ApplicationStatus @default(pendiente)
  ownerId                Int
  restaurantId           Int?              @unique
  createdAt              DateTime          @default(now())
  updatedAt              DateTime
  restaurant_owner       restaurant_owner  @relation(fields: [ownerId], references: [userId], onDelete: Cascade)
  restaurante            restaurante?      @relation(fields: [restaurantId], references: [id_restaurante])

  @@index([ownerId])
  @@index([status])
}

model client {
  userId    Int      @id
  phone     String?  @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime
  usuario   usuario  @relation(fields: [userId], references: [id_usuario], onDelete: Cascade)
}

model comprobante {
  id_comprobante     String             @id @db.VarChar(50)
  tipo               String             @db.VarChar(50)
  ruta_archivo       String             @db.VarChar(500)
  fecha_subida       DateTime           @db.Date
  id_restaurante     Int
  id_solicitud       Int
  id_usuario         Int
  restaurante        restaurante        @relation(fields: [id_restaurante], references: [id_restaurante], onDelete: Cascade)
  solicitud_registro solicitud_registro @relation(fields: [id_solicitud], references: [id_solicitud], onDelete: Cascade)
  usuario            usuario            @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@index([id_restaurante])
  @@index([id_solicitud])
  @@index([id_usuario])
}

model download {
  id               Int              @id @default(autoincrement())
  downloadCount    Int              @default(0)
  origin           DownloadOrigin
  opinion          OpinionType
  ownerId          Int
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  restaurant_owner restaurant_owner @relation(fields: [ownerId], references: [userId], onDelete: Cascade)

  @@index([origin])
  @@index([ownerId])
}

model favoritos {
  id_favorito    Int         @id @default(autoincrement())
  id_usuario     Int
  id_restaurante Int
  fecha_favorito DateTime    @db.Date
  restaurante    restaurante @relation(fields: [id_restaurante], references: [id_restaurante], onDelete: Cascade)
  usuario        usuario     @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@unique([id_usuario, id_restaurante])
  @@index([id_restaurante])
  @@index([id_usuario])
}

model menu {
  id_menu            Int         @id @default(autoincrement())
  ruta_archivo       String      @db.VarChar(500)
  id_restaurante     Int
  id_usuario         Int
  contador_descargas Int         @default(0)
  restaurante        restaurante @relation(fields: [id_restaurante], references: [id_restaurante], onDelete: Cascade)
  usuario            usuario     @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@index([id_restaurante])
  @@index([id_usuario])
}

model restaurant_owner {
  userId      Int           @id
  createdAt   DateTime      @default(now())
  application application[]
  download    download[]
  usuario     usuario       @relation(fields: [userId], references: [id_usuario], onDelete: Cascade)
}

model restaurante {
  id_restaurante     Int                @id @default(autoincrement())
  nombre             String             @db.VarChar(45)
  horario            String?            @db.VarChar(45)
  telefono           String?            @db.VarChar(45)
  etiquetas          String?            @db.VarChar(200)
  id_solicitud       Int
  id_usuario         Int
  direccion          String?            @db.VarChar(45)
  link_direccion     String?
  facebook           String?            @db.VarChar(100)
  instagram          String?            @db.VarChar(100)
  zona               String?            @db.VarChar(100)
  horario_atencion   String?            @db.VarChar(255)
  foto_portada       String?            @db.VarChar(500)
  application        application?
  comprobante        comprobante[]
  favoritos          favoritos[]
  foto_usuario       foto_usuario[]
  menu               menu[]
  solicitud_registro solicitud_registro @relation(fields: [id_solicitud], references: [id_solicitud], onDelete: Cascade)
  usuario            usuario            @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@index([id_solicitud])
  @@index([id_usuario])
  @@index([zona])
}

model revision_solicitud {
  id_revision        Int                @id @default(autoincrement())
  fecha              String             @db.VarChar(45)
  id_solicitud       Int
  id_usuario         Int
  solicitud_registro solicitud_registro @relation(fields: [id_solicitud], references: [id_solicitud], onDelete: Cascade)
  usuario            usuario            @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@index([id_solicitud])
  @@index([id_usuario])
}

model rol {
  id_rol     Int       @id @default(autoincrement())
  nombre_rol String    @db.VarChar(50)
  usuario    usuario[]
}

model solicitud_registro {
  id_solicitud                 Int                  @id @default(autoincrement())
  fecha                        DateTime             @db.Date
  estado                       String               @db.VarChar(45)
  nombre_propuesto_restaurante String               @db.VarChar(50)
  correo                       String               @db.VarChar(45)
  nombre_propietario           String               @db.VarChar(45)
  horario_atencion             String?              @db.VarChar(255)
  id_restaurante               Int?
  id_usuario                   Int
  direccion                    String?              @db.VarChar(500)
  etiquetas                    String?              @db.VarChar(200)
  facebook                     String?              @db.VarChar(100)
  foto_portada                 String?              @db.VarChar(500)
  instagram                    String?              @db.VarChar(100)
  menu_pdf                     String?              @db.VarChar(500)
  telefono                     String?              @db.VarChar(45)
  foto_2                       String?              @db.VarChar(500)
  foto_3                       String?              @db.VarChar(500)
  comprobante                  comprobante[]
  restaurante                  restaurante[]
  revision_solicitud           revision_solicitud[]
  usuario                      usuario              @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@index([estado])
  @@index([id_usuario])
}

model usuario {
  id_usuario         Int                  @id @default(autoincrement())
  nombre             String               @db.VarChar(50)
  correo             String               @unique @db.VarChar(50)
  contrasena         String               @db.VarChar(255)
  id_rol             Int
  foto_evidencia     String?              @db.VarChar(500)
  administrator      administrator?
  client             client?
  comprobante        comprobante[]
  favoritos          favoritos[]
  foto_usuario       foto_usuario[]
  menu               menu[]
  restaurant_owner   restaurant_owner?
  restaurante        restaurante[]
  revision_solicitud revision_solicitud[]
  solicitud_registro solicitud_registro[]
  rol                rol                  @relation(fields: [id_rol], references: [id_rol], onDelete: Cascade)

  @@index([correo])
  @@index([id_rol])
}

enum ApplicationStatus {
  pendiente
  aprobado
  rechazado
  en_revision
}

enum DownloadOrigin {
  Nacional
  Extranjero
}

enum OpinionType {
  La_comida
  La_ubicacion
  Recomendacion
  El_horario
  La_vista
}

model foto_usuario {
  id_foto        Int         @id @default(autoincrement())
  url_foto       String      @db.VarChar(500)
  id_usuario     Int
  id_restaurante Int
  fecha_subida   DateTime    @default(now())
  restaurante    restaurante @relation(fields: [id_restaurante], references: [id_restaurante], onDelete: Cascade)
  usuario        usuario     @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@index([id_restaurante])
  @@index([id_usuario])
}

model encuesta_restaurante {
  id_encuesta    Int         @id @default(autoincrement())
  id_usuario     Int
  id_restaurante Int
  atraccion      String?     @db.VarChar(50) // 'comida', 'ubicacion', 'horario', 'vista', 'recomendacion'
  origen         String?     @db.VarChar(50) // 'nacional', 'extranjero'
  fecha_registro DateTime    @default(now())

  @@unique([id_usuario, id_restaurante]) 
}
